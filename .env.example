# Database and Redis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/kyiv_events
REDIS_URL=redis://redis:6379/0

# Telegram Credentials
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx
# For public channel monitor (optional, Pyrogram/Telethon API details)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# AI Provider Settings
# AI_PROVIDER can be 'openai' or 'mock' (for offline/testing demo)
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Admin Portal Settings
ADMIN_EMAIL=admin@kyivevents.com
ADMIN_PASSWORD=adminpassword123
SECRET_KEY=generate_a_secure_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# System Configurations
APP_BASE_URL=http://localhost:8000
CRAWLER_USER_AGENT=KyivEventGuideCrawler/1.0 (+http://localhost:8000)
PORT=8000
AUTO_PUBLISH=True
